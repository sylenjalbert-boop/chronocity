rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Saves et méta : chaque utilisateur accède uniquement à ses propres données
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Leaderboard : lecture publique, écriture si le docId commence par l'uid du joueur
    match /leaderboard/{entryId} {
      allow read: if true;
      allow write: if request.auth != null && entryId.matches(request.auth.uid + '.*');
    }

    // Config version : lecture publique, écriture admin uniquement
    match /config/{document} {
      allow read: if true;
      allow write: if false;
    }
  }
}
